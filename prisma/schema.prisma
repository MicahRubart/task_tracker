generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          String           @id @default(cuid())
  name        String           @unique
  department  Department
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  tasks       Task[]           @relation("TaskOwner")
  partners    TaskPartner[]
  notes       TaskNote[]
  dateChanges DueDateHistory[]
}

model Task {
  id             String           @id @default(cuid())
  title          String
  department     Department
  employeeId     String
  employee       Employee         @relation("TaskOwner", fields: [employeeId], references: [id])
  dueDate        DateTime?
  status         TaskStatus       @default(NOT_STARTED)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  partners       TaskPartner[]
  notes          TaskNote[]
  dueDateHistory DueDateHistory[]
  linksFrom      TaskLink[]       @relation("LinkSource")
  linksTo        TaskLink[]       @relation("LinkTarget")
}

model TaskPartner {
  taskId     String
  employeeId String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@id([taskId, employeeId])
}

model TaskNote {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  body      String
  authorId  String
  author    Employee @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model DueDateHistory {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  oldDate     DateTime?
  newDate     DateTime?
  changedById String
  changedBy   Employee @relation(fields: [changedById], references: [id])
  changedAt   DateTime @default(now())
}

model TaskLink {
  id           String   @id @default(cuid())
  sourceTaskId String
  targetTaskId String
  linkType     LinkType @default(RELATES_TO)
  sourceTask   Task     @relation("LinkSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask   Task     @relation("LinkTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)
}

enum Department {
  WEB_SERVICES
  TRAINING
  IMPLEMENTATION
  CONVERSION
  STRATEGIC_SOLUTIONS
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum LinkType {
  RELATES_TO
  BLOCKS
  SUBTASK_OF
}

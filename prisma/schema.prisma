generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          String           @id @default(cuid())
  name        String           @unique
  departments Department[]
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  tasks       Task[]           @relation("TaskOwner")
  partners    TaskPartner[]
  notes       TaskNote[]
  dateChanges DueDateHistory[]
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  department  Department
  description String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  tasks       Task[]
}

model Task {
  id             String           @id @default(cuid())
  title          String
  department     Department
  employeeId     String
  employee       Employee         @relation("TaskOwner", fields: [employeeId], references: [id])
  goalId         String?
  goal           Goal?            @relation(fields: [goalId], references: [id])
  dueDate        DateTime?
  status         TaskStatus       @default(NOT_STARTED)
  stuckDeadline  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  partners       TaskPartner[]
  notes          TaskNote[]
  dueDateHistory DueDateHistory[]
  linksFrom      TaskLink[]       @relation("LinkSource")
  linksTo        TaskLink[]       @relation("LinkTarget")
  checklistItems ChecklistItem[]
}

model TaskPartner {
  taskId     String
  employeeId String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@id([taskId, employeeId])
}

model TaskNote {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  body      String
  authorId  String
  author    Employee @relation(fields: [authorId], references: [id])
  noteType  NoteType @default(REGULAR)
  createdAt DateTime @default(now())
}

model DueDateHistory {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  oldDate     DateTime?
  newDate     DateTime?
  reason      String
  changedById String
  changedBy   Employee  @relation(fields: [changedById], references: [id])
  changedAt   DateTime  @default(now())
}

model TaskLink {
  id           String   @id @default(cuid())
  sourceTaskId String
  targetTaskId String
  linkType     LinkType @default(RELATES_TO)
  sourceTask   Task     @relation("LinkSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask   Task     @relation("LinkTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)
}

model ChecklistItem {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
}

enum Department {
  WEB_SERVICES
  TRAINING
  IMPLEMENTATION
  CONVERSION
  STRATEGIC_SOLUTIONS
  OPERATIONS
  LEADERSHIP
}

enum TaskStatus {
  NOT_STARTED
  STARTED
  STUCK
  ON_TRACK
  OFF_TRACK
  ESCALATED
  COMPLETE
}

enum NoteType {
  REGULAR
  DATE_CHANGE
  STATUS_CHANGE
}

enum LinkType {
  RELATES_TO
  BLOCKS
  SUBTASK_OF
}

model DepartmentSettings {
  department      Department @id
  teamsWebhookUrl String?
}

model NotificationRule {
  id              String            @id @default(cuid())
  department      Department
  name            String
  triggerType     TriggerType
  triggerDays     Int
  messageTemplate String
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  logs            NotificationLog[]
}

model NotificationLog {
  id      String           @id @default(cuid())
  ruleId  String
  rule    NotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  taskId  String
  sentAt  DateTime         @default(now())
}

enum TriggerType {
  OVERDUE_BY_DAYS
  DUE_IN_DAYS
  NO_UPDATE_IN_DAYS
}
